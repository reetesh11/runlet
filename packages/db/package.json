{
  "name": "@runlet/db",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env.local src/migrate.ts",
    "db:seed": "tsx --env-file=../../.env.local src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx --env-file=../../.env.local src/reset.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "@neondatabase/serverless": "latest",
    "postgres": "^3.4.9",
    "pg": "^8.11.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}