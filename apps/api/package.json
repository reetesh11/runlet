{
  "name": "@runlet/api",
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk/client-s3 --external:ioredis --external:bullmq --external:postgres --external:hono --external:@hono/node-server --external:@hono/zod-validator --external:nanoid --external:zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.2.0",
    "@hono/node-server": "^1.9.0",
    "@hono/zod-validator": "^0.2.0",
    "@runlet/db": "workspace:*",
    "@runlet/schemas": "workspace:*",
    "@runlet/types": "workspace:*",
    "@runlet/utils": "workspace:*",
    "@runlet/queue": "workspace:*",
    "@runlet/storage": "workspace:*",
    "@runlet/connectors": "workspace:*",
    "drizzle-orm": "latest",
    "postgres": "latest",
    "zod": "^3.22.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}