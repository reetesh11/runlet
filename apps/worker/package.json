{
  "name": "@runlet/worker",
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk/client-s3 --external:ioredis --external:bullmq --external:postgres --external:@anthropic-ai/sdk --external:openai --external:zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@runlet/db": "workspace:*",
    "@runlet/types": "workspace:*",
    "@runlet/utils": "workspace:*",
    "@runlet/queue": "workspace:*",
    "@runlet/storage": "workspace:*",
    "@runlet/connectors": "workspace:*",
    "@anthropic-ai/sdk": "^0.24.0",
    "openai": "^4.47.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "drizzle-orm": "latest",
    "postgres": "latest",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}