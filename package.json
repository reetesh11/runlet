{
  "name": "runlet",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@runlet/db",
    "db:migrate": "turbo run db:migrate --filter=@runlet/db",
    "db:seed": "turbo run db:seed --filter=@runlet/db",
    "db:studio": "turbo run db:studio --filter=@runlet/db",
    "db:reset": "turbo run db:reset --filter=@runlet/db",
    "r2:setup": "tsx infra/r2/setup-buckets.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0"
  }
}
