#!/bin/sh
echo "🔍 Running TypeScript check before push..."

# Get the repo root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Remove .next generated types — they cause false positives
rm -rf "$REPO_ROOT/apps/web/.next/types" 2>/dev/null

# Run tsc from web directory
cd "$REPO_ROOT/apps/web"
npx tsc --noEmit --skipLibCheck
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix them before pushing."
  exit 1
fi

echo "✅ TypeScript check passed."
exit 0



